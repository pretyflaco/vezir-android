<?xml version="1.0" encoding="utf-8"?>
<!--
  Cleartext HTTP is allowed only for the specific Tailscale-style hosts
  listed below. HTTPS is allowed everywhere. Anything else is rejected.

  Build-time list. To add a host the operator controls, edit this file
  and rebuild. v1 ships with no preset cleartext hosts; the user must
  point the app at a host they edit in here.
-->
<network-security-config>
    <base-config cleartextTrafficPermitted="false">
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </base-config>

    <!-- Cleartext allow-list for known Tailscale-only Vezir servers.
         <domain> does not accept CIDR; list each FQDN/IP individually.
         Add hosts here and rebuild to point this APK at a different
         server. -->
    <domain-config cleartextTrafficPermitted="true">
        <domain includeSubdomains="false">muscle.tail178bd.ts.net</domain>
        <!-- Tailscale IP fallback when MagicDNS isn't available. -->
        <domain includeSubdomains="false">100.107.34.79</domain>
    </domain-config>
</network-security-config>
