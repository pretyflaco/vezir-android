<?xml version="1.0" encoding="utf-8"?>
<!--
  Monochrome launcher variant for Android 13+ themed-icon mode.
  Same silhouette as the brand mark, single fill color (the OS
  re-tints this drawable based on the user's wallpaper palette).

  Mirrors the 0.7× pivot-centered scale-down applied to
  ic_launcher_foreground.xml so the themed icon stays inside the safe
  zone of the adaptive icon viewport.
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="256"
    android:viewportHeight="256">

    <group
        android:scaleX="0.7"
        android:scaleY="0.7"
        android:pivotX="128"
        android:pivotY="128">

        <path
            android:fillColor="#000000"
            android:pathData="M64,96 L64,64 L80,80 L96,64 L112,80 L128,64 L144,80 L160,64 L176,80 L192,64 L192,96 Z" />
        <path
            android:fillColor="#000000"
            android:pathData="M92,96 L164,96 L176,196 L80,196 Z" />
        <path
            android:fillColor="#000000"
            android:pathData="M48,196 L208,196 A6,6 0 0 1 214,202 L214,218 A6,6 0 0 1 208,224 L48,224 A6,6 0 0 1 42,218 L42,202 A6,6 0 0 1 48,196 Z" />
        <path
            android:fillColor="#000000"
            android:pathData="M128,24 A12,12 0 1 0 128,48 A12,12 0 1 0 128,24 Z" />
    </group>
</vector>
